---
// src/pages/index.astro
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Coming Soon</title>
    <style>
      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
      }
      body {
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #0a0a0a;
        background-image:
          radial-gradient(circle, #333 1px, transparent 1px);
        background-size: 24px 24px;
        color: #f5f5f5;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        text-align: center;
        position: relative;
        overflow: hidden;
      }

      /* Scattered color accents over the dot grid */
      body::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
          radial-gradient(circle at 78% 12%, rgba(56, 189, 248, 0.9) 1.5px, transparent 1.5px),
          radial-gradient(circle at 82% 40%, rgba(45, 212, 191, 0.8) 1.5px, transparent 1.5px),
          radial-gradient(circle at 68% 45%, rgba(56, 189, 248, 0.7) 1.5px, transparent 1.5px),
          radial-gradient(circle at 30% 78%, rgba(45, 212, 191, 0.7) 1.5px, transparent 1.5px),
          radial-gradient(circle at 34% 92%, rgba(56, 189, 248, 0.6) 1.5px, transparent 1.5px),
          radial-gradient(circle at 20% 85%, rgba(45, 212, 191, 0.5) 1.5px, transparent 1.5px);
        background-size: 24px 24px;
        pointer-events: none;
      }

      /* Soft vignette so the grid fades toward the edges */
      body::after {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, transparent 40%, #0a0a0a 90%);
        pointer-events: none;
      }

      .container {
        padding: 2rem;
        position: relative;
        z-index: 1;
      }
      h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
      }
      p {
        color: #a3a3a3;
        font-size: 1.1rem;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Coming Soon</h1>
      <p>We're working on something. Check back shortly.</p>
    </div>
  </body>
</html>
