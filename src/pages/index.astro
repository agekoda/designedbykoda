---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE_DESCRIPTION } from '../consts';

// Controls the order projects appear in on the homepage grid specifically.
// Read left-to-right, top-to-bottom. Anything not listed here falls in
// afterwards, sorted by its `order` field in the content frontmatter.
const homepageOrder = [
	'phantomware',
	'vfd-display-board',
	'smart-energy-meter-puck',
	'rf-tool',
	'lora-portable-messenger',
	'nrf-box',
	'air-quality-monitor',
	'nrf24-audio-radio',
];

const allProjects = await getCollection('projects');
const byOrderField = [...allProjects].sort((a, b) => a.data.order - b.data.order);

const projects = [
	...homepageOrder
		.map((slug) => allProjects.find((p) => p.id === slug))
		.filter((p) => p !== undefined),
	...byOrderField.filter((p) => !homepageOrder.includes(p.id)),
];
---

<Layout title="designedbykoda" description={SITE_DESCRIPTION}>
	<section class="hero">
		<h1>Hi, I'm Koda 👋</h1>
		<p>
			Custom PCBs, ESP32 firmware, RF tools, and the occasional resin enclosure that fits
			together better than it has any right to.
		</p>
		<div class="hero-links">
			<a class="button" href="/projects">See all projects</a>
			<a class="button ghost" href="/about">About me</a>
		</div>
	</section>

	<section class="featured">
		<div class="featured-heading">
			<h2>Projects</h2>
			<a href="/projects">View all &rarr;</a>
		</div>
		<div class="grid">
			{
				projects.map((project) => (
					<ProjectCard
						slug={project.id}
						title={project.data.title}
						tagline={project.data.tagline}
						category={project.data.category}
						status={project.data.status}
						heroImage={project.data.heroImage}
					/>
				))
			}
		</div>
	</section>
</Layout>

<style>
	.hero {
		text-align: center;
		padding: 3em 0 4em 0;
	}
	.hero h1 {
		font-size: 2.8em;
		margin-bottom: 0.4em;
	}
	.hero p {
		max-width: 560px;
		margin: 0 auto 1.8em auto;
		font-size: 1.1em;
	}
	.hero-links {
		display: flex;
		gap: 0.8em;
		justify-content: center;
	}
	.button {
		display: inline-block;
		padding: 0.7em 1.4em;
		border-radius: 999px;
		background: var(--fg);
		color: var(--bg);
		font-weight: 700;
		font-size: 0.95em;
	}
	.button:hover {
		background: var(--accent);
		color: var(--bg);
	}
	.button.ghost {
		background: transparent;
		color: var(--fg);
		border: 1px solid var(--border);
		font-weight: 400;
	}
	.button.ghost:hover {
		border-color: var(--accent);
		color: var(--fg);
	}
	.featured-heading {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		border-bottom: 1px solid var(--border);
		padding-bottom: 0.6em;
		margin-bottom: 1.5em;
	}
	.featured-heading h2 {
		font-size: 1.4em;
	}
	.featured-heading a {
		font-size: 0.9em;
		color: var(--muted);
	}
	.featured-heading a:hover {
		color: var(--fg);
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.4em;
	}
	@media (max-width: 720px) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 480px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 520px) {
		.hero h1 {
			font-size: 2.1em;
		}
	}
</style>
