---
// src/pages/index.astro
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Coming Soon</title>
    <style>
      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
      }
      body {
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #0a0a0a;
        background-image:
          radial-gradient(circle, rgba(80, 160, 220, 0.35) 1px, transparent 1px);
        background-size: 22px 22px;
        color: #f5f5f5;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        text-align: center;
        position: relative;
        overflow: hidden;
      }
      .glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(70px);
        pointer-events: none;
        z-index: 0;
      }
      .glow-blue {
        width: 500px;
        height: 500px;
        top: -10%;
        right: -5%;
        background: radial-gradient(circle, rgba(60, 140, 220, 0.14), transparent 70%);
      }
      .glow-teal {
        width: 400px;
        height: 400px;
        bottom: -10%;
        left: 5%;
        background: radial-gradient(circle, rgba(60, 200, 190, 0.12), transparent 70%);
      }
      .glow-pink {
        width: 350px;
        height: 350px;
        top: 10%;
        left: -8%;
        background: radial-gradient(circle, rgba(230, 160, 200, 0.10), transparent 70%);
      }
      .glow-purple {
        width: 380px;
        height: 380px;
        bottom: 5%;
        right: 0%;
        background: radial-gradient(circle, rgba(180, 150, 230, 0.10), transparent 70%);
      }
      .container {
        padding: 2rem;
        position: relative;
        z-index: 1;
      }
      h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
      }
      p {
        color: #a3a3a3;
        font-size: 1.1rem;
        margin: 0;
      }
      .handle {
        position: absolute;
        bottom: 1.5rem;
        right: 1.5rem;
        color: #a3a3a3;
        font-size: 1.1rem;
        margin: 0;
        z-index: 1;
      }
    </style>
  </head>
  <body>
    <div class="glow glow-blue"></div>
    <div class="glow glow-teal"></div>
    <div class="glow glow-pink"></div>
    <div class="glow glow-purple"></div>
    <div class="container">
      <h1>Coming Soon</h1>
      <p>We're working on something. Check back shortly.</p>
    </div>
    <p class="handle">@designedbykoda</p>
  </body>
</html>
